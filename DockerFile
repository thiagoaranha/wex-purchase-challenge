# ==========================================
# STAGE 1: Build
# ==========================================
FROM node:22-alpine AS builder

# Use corepack for a more robust pnpm installation
RUN corepack enable && corepack prepare pnpm@10.33.1 --activate

WORKDIR /usr/src/app

# Copy configuration and dependency files
COPY package.json pnpm-lock.yaml .npmrc ./

# Install ALL dependencies
RUN pnpm install --frozen-lockfile

# Copy the rest of the code
COPY . .

# Generate Prisma Client
RUN pnpm prisma:generate

# Build the project
RUN pnpm run build

# ==========================================
# STAGE 2: Production
# ==========================================
FROM node:22-alpine AS production

RUN corepack enable && corepack prepare pnpm@10.33.1 --activate

ENV NODE_ENV=production

WORKDIR /usr/src/app

# Copy only necessary files
COPY --from=builder /usr/src/app/package.json ./
COPY --from=builder /usr/src/app/pnpm-lock.yaml ./
COPY --from=builder /usr/src/app/.npmrc ./
COPY --from=builder /usr/src/app/dist ./dist
# Copy the prisma folder to have schema and migrations
COPY --from=builder /usr/src/app/prisma ./prisma
# Copy the generated Prisma Client with engine binaries
COPY --from=builder /usr/src/app/src/generated/prisma ./src/generated/prisma

# Install only production dependencies
RUN pnpm install --prod --frozen-lockfile

# Install prisma CLI globally or locally to run migrations
RUN pnpm add prisma

EXPOSE 3000

# Entry point: run migrations and then start the API
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/main"]
