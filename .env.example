NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://wex_user:wex_password@localhost:5432/wex_db?schema=public
TREASURY_API_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

TREASURY_API_TIMEOUT_MS=10000
TREASURY_CACHE_TTL_MS=300000

# Health check
HEALTH_CHECK_TIMEOUT_MS=5000

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# Auth client credentials (used by POST /auth/token)
AUTH_CLIENT_ID=admin # change-me-in-production
AUTH_CLIENT_SECRET=admin1234 # change-me-in-production